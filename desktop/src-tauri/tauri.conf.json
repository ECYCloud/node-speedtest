{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stair Speedtest",
  "version": "0.1.0",
  "identifier": "com.stairspeedtest.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Stair Speedtest",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 680,
        "decorations": true,
        "resizable": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "copyright": "MIT License",
    "resources": ["engine/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false,
        "installMode": "currentUser",
        "installerHooks": "installer-hooks.nsh",
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/header.bmp"
      }
    }
  }
}
