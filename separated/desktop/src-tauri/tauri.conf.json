{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stair Speedtest",
  "version": "0.1.1",
  "identifier": "com.stairspeedtest.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "beforeBundleCommand": "node scripts/sync-nsis-lang.cjs",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Stair Speedtest",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 680,
        "decorations": true,
        "resizable": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "rpm", "appimage", "dmg", "app"],
    "createUpdaterArtifacts": true,
    "copyright": "MIT",
    "license": "MIT",
    "resources": [
      "engine/**/*",
      "LICENSE",
      "NOTICE",
      "licenses/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false,
        "installMode": "currentUser",
        "installerHooks": "installer-hooks.nsh",
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/header.bmp"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/ECYCloud/stairspeedtest-reborn-mihomo/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUxQTI2MjlGNTYwOTlCREMKUldUY213bFduMktpNFVVTnhHTDgwRjJTWnRUVEdBT1BON3dOUXdEWXFlN0hES214bFM1NHNadTMK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
